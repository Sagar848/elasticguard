# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Next.js build output ──────────────────────────────────────────────────────
# The builder stage runs `npm run build` inside the container,
# so any local .next/ is irrelevant and just wastes transfer time
.next/
out/

# ── Env files (secrets — never bake into image) ───────────────────────────────
.env
.env.*
!.env.example

# ── Test / Dev ────────────────────────────────────────────────────────────────
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__/
coverage/
.nyc_output/

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.sw[pon]
.DS_Store
Thumbs.db
*~

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Docker itself ─────────────────────────────────────────────────────────────
Dockerfile
.dockerignore

# ── Docs / CI ─────────────────────────────────────────────────────────────────
*.md
.github/
docs/
