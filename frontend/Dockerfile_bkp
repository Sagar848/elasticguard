# ─────────────────────────────────────────────────────────────────────────────
#  ElasticGuard Frontend Dockerfile
#  • Multi-stage: deps → builder → slim runtime
#  • Supports private/air-gapped registry via REGISTRY_PREFIX build-arg
#  • Next.js standalone output for minimal image size
# ─────────────────────────────────────────────────────────────────────────────

ARG REGISTRY_PREFIX=""
ARG NODE_IMAGE=node:20-alpine

# ── Stage 1: Install deps (separate layer — cached unless package.json changes)
FROM ${REGISTRY_PREFIX}${NODE_IMAGE} AS deps

WORKDIR /app

COPY package.json package-lock.json* ./

# Use ci for reproducible installs; fallback to install if no lockfile
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

# ── Stage 2: Build the Next.js app ───────────────────────────────────────────
FROM ${REGISTRY_PREFIX}${NODE_IMAGE} AS builder

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

# Build args — override at build time for the API URL
ARG NEXT_PUBLIC_API_URL=http://backend:8000
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

RUN npm run build

# ── Stage 3: Minimal production image ────────────────────────────────────────
FROM ${REGISTRY_PREFIX}${NODE_IMAGE} AS runtime

RUN addgroup --system --gid 1001 nodejs && \
    adduser  --system --uid 1001 nextjs

WORKDIR /app

COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static     ./.next/static
# public/ is optional — ignore error if it doesn't exist
COPY --from=builder --chown=nextjs:nodejs /app/public           ./public 2>/dev/null || true

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD wget -qO- http://localhost:3000/ > /dev/null || exit 1

CMD ["node", "server.js"]
